# Backend environment variables — copy this file to `.env` and fill in real values.
# These are read on app startup; do NOT commit `.env` to version control.

# Optional: enables AI-powered roadmap generation. If empty, the static
# roadmaps in backend/data/roadmaps.json are used and the AI endpoint
# returns HTTP 503.
NEBIUS_API_KEY=

# Defaults to meta-llama/Llama-3.3-70B-Instruct
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
