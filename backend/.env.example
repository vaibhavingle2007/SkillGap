# Backend environment variables — copy this file to `.env` and fill in real values.
# These are read on app startup; do NOT commit `.env` to version control.

# Comma-separated list of allowed CORS origins.
# Defaults to localhost + the deployed frontend. Override for your own domain.
# Example: FRONTEND_URL=https://your-site.vercel.app,http://localhost:3000
FRONTEND_URL=

# Optional: enables AI-powered roadmap generation. If empty, the static
# roadmaps in backend/data/roadmaps.json are used and the AI endpoint
# returns HTTP 503.
NVIDIA_API_KEY=

# Defaults to nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
